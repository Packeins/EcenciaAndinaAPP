PORT=3001

# Origenes permitidos para consumir la API desde navegador.
# En produccion/preproduccion agrega la URL real del frontend, por ejemplo:
# CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Opcional: solo si alguna ruta o script legacy lo requiere.
SUPABASE_KEY=TU_ANON_O_PUBLISHABLE_KEY
SUPABASE_ANON_KEY=TU_ANON_O_PUBLISHABLE_KEY

# n8n: webhook que dispara el envio manual del menu desde el tablero.
N8N_MENU_WEBHOOK_URL=http://localhost:7000/webhook/eciencia-enviar-menu-manual

# Retencion de imagenes generadas para menus de Telegram.
MENU_IMAGE_RETENTION_DAYS=14

# Opcional para mantenimiento/admin local. No lo necesita el backend en runtime normal.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
