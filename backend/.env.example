PORT=3001

# Supabase
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Opcional: solo si alguna ruta o script legacy lo requiere.
SUPABASE_KEY=TU_ANON_O_PUBLISHABLE_KEY
SUPABASE_ANON_KEY=TU_ANON_O_PUBLISHABLE_KEY

# n8n: webhook que dispara el envio manual del menu desde el tablero.
N8N_MENU_WEBHOOK_URL=http://localhost:7000/webhook/eciencia-enviar-menu-manual

# Opcional para mantenimiento/admin local. No lo necesita el backend en runtime normal.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
