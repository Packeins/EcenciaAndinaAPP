# Core n8n local
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:7000
WEBHOOK_URL=http://localhost:7000
N8N_SECURE_COOKIE=false
N8N_DIAGNOSTICS_ENABLED=false
GENERIC_TIMEZONE=America/Bogota
TZ=America/Bogota

# Requerido si n8n usa Postgres en Supabase u otro Postgres.
# Si usas SQLite local de n8n para pruebas, puedes omitir este bloque.
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=TU_HOST_POSTGRES
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=TU_USUARIO_POSTGRES
DB_POSTGRESDB_PASSWORD=TU_PASSWORD_POSTGRES
DB_POSTGRESDB_SCHEMA=n8n
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false
N8N_ENCRYPTION_KEY=GENERA_UNA_CLAVE_LARGA_Y_UNICA

# Integraciones del workflow Eciencia
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
TELEGRAM_BOT_TOKEN=TU_TELEGRAM_BOT_TOKEN

N8N_ECIENCIA_TIMEZONE=America/Bogota
N8N_ECIENCIA_MENU_IMAGE_URL=https://TU-PROYECTO.supabase.co/storage/v1/object/public/eciencia-menu-assets/telegram/eciencia-menu-demo.png
N8N_ECIENCIA_PRODUCTO_ALMUERZO_NOMBRE=Almuerzo Telegram
N8N_ECIENCIA_ORIGEN_NOMBRE=Telegram
N8N_ECIENCIA_ESTADO_RESERVADO_NOMBRE=Reservado

# Solo para entornos Windows con certificados interceptados por antivirus/proxy.
# No usar en produccion.
# NODE_TLS_REJECT_UNAUTHORIZED=0
